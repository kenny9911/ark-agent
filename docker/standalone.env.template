# Standalone .env template for Docker deployments.
# Copy this file to .env in the project root or mount it directly.

# ---- Database (Postgres) ----------------------------------------------------
DATABASE_URL=postgres://arkagent:changeme@postgres:5432/arkagent?sslmode=disable
DIRECT_DATABASE_URL=postgres://arkagent:changeme@postgres:5432/arkagent?sslmode=disable

# ---- Authentication ---------------------------------------------------------
SESSION_SECRET=change-me-with-32-byte-hex-secret
SESSION_COOKIE_NAME=ark_session
SESSION_TTL_DAYS=30

# ---- Agent Manager integration ----------------------------------------------
AGENT_MANAGER_MODE=mock
AGENT_MANAGER_BASE_URL=http://host.docker.internal:4000
AGENT_MANAGER_API_KEY=your-api-key
AGENT_MANAGER_WEBHOOK_SECRET=your-webhook-secret

# ---- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
