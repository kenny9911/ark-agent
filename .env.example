# =====================================================================
# ArkAgent — environment template. Copy to `.env` and fill in real values.
# Never commit a real `.env` (it is git-ignored).
# =====================================================================

# ---- Database (Postgres) ----------------------------------------------------
# Pooled connection (e.g. pgbouncer transaction mode) used by the app at runtime.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/arkagent?sslmode=require
# Direct (non-pooled) connection used for migrations / drizzle-kit. May equal
# DATABASE_URL if you do not use a connection pooler.
DIRECT_DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/arkagent?sslmode=require

# ---- Authentication ---------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-32-byte-hex-secret
SESSION_COOKIE_NAME=ark_session
SESSION_TTL_DAYS=30

# ---- Agent Manager integration ----------------------------------------------
# mock = built-in simulator (no external service needed); live = call the real one.
AGENT_MANAGER_MODE=mock
AGENT_MANAGER_BASE_URL=http://localhost:4000
# Bearer token ArkAgent sends to the Agent Manager on every request.
AGENT_MANAGER_API_KEY=replace-with-agent-manager-api-key
# Shared secret the Agent Manager uses to sign webhooks back to ArkAgent (HMAC-SHA256).
AGENT_MANAGER_WEBHOOK_SECRET=replace-with-webhook-shared-secret

# ---- OpenClaw Manager API ---------------------------------------------------
# Base URL of the OpenClaw Manager service
OPENCLAW_MANAGER_API_URL=http://10.21.27.155:18090
# Bearer token for OpenClaw Manager API
OPENCLAW_MANAGER_API_KEY=replace-with-openclaw-manager-api-key

# ---- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
